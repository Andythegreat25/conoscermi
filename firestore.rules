rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    function uidUnchanged() {
      return !('uid' in request.resource.data) || request.resource.data.uid == request.auth.uid;
    }
    function uidNotModified() {
      return !('uid' in request.resource.data) || request.resource.data.uid == resource.data.uid;
    }
    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    // Validators
    function isValidUserSettings() {
      return hasOnlyAllowedFields(['remindersEnabled', 'dismissedDate', 'uid']) &&
             (!('remindersEnabled' in request.resource.data) || request.resource.data.remindersEnabled is bool) &&
             (!('dismissedDate' in request.resource.data) || request.resource.data.dismissedDate is string || request.resource.data.dismissedDate == null) &&
             (!('uid' in request.resource.data) || request.resource.data.uid is string);
    }

    function isValidDiaryEntry() {
      return hasOnlyAllowedFields(['id', 'timestamp', 'date', 'time', 'mood', 'note', 'uid']) &&
             request.resource.data.id is string &&
             request.resource.data.id.size() < 100 &&
             request.resource.data.timestamp is number &&
             request.resource.data.date is string &&
             request.resource.data.date.size() < 100 &&
             request.resource.data.time is string &&
             request.resource.data.time.size() < 100 &&
             request.resource.data.mood is string &&
             request.resource.data.mood.size() < 50 &&
             (!('note' in request.resource.data) || (request.resource.data.note is string && request.resource.data.note.size() < 5000)) &&
             request.resource.data.uid is string;
    }

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUserSettings() && uidUnchanged();
      allow update: if isOwner(userId) && isValidUserSettings() && uidNotModified();

      match /entries/{entryId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidDiaryEntry() && uidUnchanged();
        allow update: if isOwner(userId) && isValidDiaryEntry() && uidNotModified();
        allow delete: if isOwner(userId);
      }
    }
  }
}
